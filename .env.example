# 공공데이터포털(data.go.kr) Encoding serviceKey
# K-Startup, 중소벤처24 공고(15113191), 벤처기업확인서(15106235) 등에 사용
PUBLIC_DATA_SERVICE_KEY=your_data_go_kr_service_key_here

# 중소벤처24 Open API 전용 토큰 (smes.go.kr에서 별도 신청·발급)
# 포털에서 복사한 Encoding 키(%2B 등)를 그대로 저장하면 됩니다.
SMES24_API_KEY=your_smes24_api_key_here

# 기업마당(bizinfo.go.kr) API 인증키 — data.go.kr 아닌 bizinfo.go.kr 자체 포털에서 신청
# 신청 경로: https://www.bizinfo.go.kr/web/lay1/program/S1T175C174/apiDetail.do?id=bizinfoApi
BIZINFO_API_KEY=your_bizinfo_api_key_here

# (선택) MCP 도구 응답 JSON을 들여쓰기해 사람이 읽기 쉽게 출력. 미설정 시 compact(LLM 토큰 절감).
# GOV_MCP_JSON_PRETTY=1
